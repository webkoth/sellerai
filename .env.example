# SellerAI — Environment Variables
# Скопируйте этот файл в .env и заполните своими токенами
# cp .env.example .env

# ===== WILDBERRIES =====
# Получить: seller.wildberries.ru → Настройки → Доступ к API
WB_API_TOKEN=your_wb_token_here

# ===== OZON =====
# Получить: seller.ozon.ru → Настройки → API ключи
OZON_CLIENT_ID=your_client_id
OZON_API_TOKEN=your_api_token

# ===== ЯНДЕКС.МАРКЕТ =====
# Получить: partner.market.yandex.ru → Настройки → API
YM_API_TOKEN=your_ym_token
YM_BUSINESS_ID=your_business_id
YM_CAMPAIGN_ID=your_campaign_id

# ===== FIRECRAWL (опционально) =====
# Получить: firecrawl.dev/app/api-keys
# Используется для парсинга документации маркетплейсов
FIRECRAWL_API_KEY=your_firecrawl_key

# ===== БАЗА ДАННЫХ =====
# PostgreSQL для хранения истории операций
DATABASE_URL=postgresql://localhost:5432/sellerai
