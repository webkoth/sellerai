{
  "mcpServers": {
    "wb-mcp": {
      "command": "node",
      "args": ["mcp/wb-mcp/dist/index.js"],
      "env": {
        "DATABASE_URL": "postgresql://localhost:5432/sellerai"
      }
    },
    "ozon-mcp": {
      "command": "node",
      "args": ["mcp/ozon-mcp/dist/index.js"],
      "env": {
        "DATABASE_URL": "postgresql://localhost:5432/sellerai"
      }
    },
    "ym-mcp": {
      "command": "node",
      "args": ["mcp/ym-mcp/dist/index.js"],
      "env": {
        "DATABASE_URL": "postgresql://localhost:5432/sellerai"
      }
    },
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost:5432/sellerai"
      ]
    }
  }
}
