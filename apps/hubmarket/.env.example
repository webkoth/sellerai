# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=hubmarket
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Encryption (for marketplace credentials)
ENCRYPTION_KEY=your-encryption-key-32-chars-min

# Wildberries API (example)
# WB_TOKEN=your-wildberries-token

# Ozon API (example)
# OZON_CLIENT_ID=your-client-id
# OZON_API_KEY=your-api-key

# Yandex Market API (example)
# YANDEX_API_KEY=your-api-key
# YANDEX_BUSINESS_ID=your-business-id
# YANDEX_CAMPAIGN_ID=your-campaign-id
