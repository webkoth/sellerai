{
  "name": "@hubmarket/source",
  "version": "0.0.1",
  "description": "Marketplace Sync Platform - синхронизация товаров между маркетплейсами",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nx run-many --target=build --all",
    "build:api": "nx build api",
    "build:workers": "nx build workers",
    "start": "nx serve api",
    "start:dev": "nx serve api --watch",
    "start:workers": "nx serve workers",
    "start:workers:dev": "nx serve workers --watch",
    "start:all": "concurrently \"npm run start:dev\" \"npm run start:workers:dev\"",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d ./typeorm.config.ts",
    "migration:run": "npm run typeorm -- migration:run -d ./typeorm.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d ./typeorm.config.ts",
    "migration:show": "npm run typeorm -- migration:show -d ./typeorm.config.ts",
    "migration:create": "npm run typeorm -- migration:create",
    "cli": "ts-node -r tsconfig-paths/register apps/cli/src/main.ts",
    "cli:categories:list": "npm run cli -- categories list",
    "cli:categories:import": "npm run cli -- categories import",
    "cli:categories:create": "npm run cli -- categories create",
    "cli:categories:export": "npm run cli -- categories export",
    "cli:categories:wizard": "npm run cli -- categories wizard",
    "cli:sync:status": "npm run cli -- sync status",
    "cli:sync:accounts": "npm run cli -- sync accounts",
    "cli:sync:products": "npm run cli -- sync products"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/typeorm": "^10.0.1",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "commander": "^14.0.2",
    "dotenv": "^16.3.1",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@nx/js": "^17.2.8",
    "@nx/nest": "^17.2.8",
    "@nx/node": "^17.2.8",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "nx": "^17.2.8",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
