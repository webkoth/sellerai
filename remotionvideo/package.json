  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.479",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc",
    "render:alpha": "remotion render --codec=prores --prores-profile=4444 --pixel-format=yuva444p10le --image-format=png",
