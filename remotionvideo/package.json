  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.479",
    "@remotion/google-fonts": "^4.0.479",
    "@remotion/tailwind-v4": "^4.0.479",
    "@remotion/transitions": "^4.0.479",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.479",
